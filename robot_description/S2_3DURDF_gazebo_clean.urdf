</noise>
</ray>
<plugin name="laser_back_controller" filename="libgazebo_ros_ray_sensor.so">
<ros>
<namespace>/</namespace>
<remapping>~/out:=scan_back</remapping>
</ros>
<output_type>sensor_msgs/LaserScan</output_type>
<frame_name>laser_back</frame_name>
</plugin>
</sensor>
