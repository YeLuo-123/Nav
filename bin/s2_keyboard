#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "${ROOT}/setup/s2_bundle_env.sh" "${S2_NETWORK_INTERFACE:-}"

set +u
source "${ROOT}/tools/s2_nav2_source_env.sh"
set -u

MODE="${1:-preview}"
case "${MODE}" in
  preview)
    MOTION_ARGS=()
    echo "[s2-keyboard] PREVIEW ONLY: commands will not reach the chassis"
    ;;
  real)
    MOTION_ARGS=(--enable-motion)
    if [[ "${S2_SKIP_SET_MANUAL_MODE:-0}" == "1" ]]; then
      MOTION_ARGS+=(--skip-set-manual-mode)
    fi
    if [[ "${S2_SKIP_EXIT_PARKING:-0}" == "1" ]]; then
      MOTION_ARGS+=(--skip-exit-parking)
    fi
    echo "[s2-keyboard] REAL MOTION MODE"
    echo "[s2-keyboard] clear the area and keep the emergency stop within reach"
    ;;
  *)
    echo "Usage: $0 {preview|real}" >&2
    exit 2
    ;;
esac

if [[ ! -t 0 ]]; then
  echo "[s2-keyboard] an interactive terminal is required" >&2
  exit 1
fi

if ! ros2 pkg executables teleop_twist_keyboard 2>/dev/null \
  | awk '$2 == "teleop_twist_keyboard" { found=1 } END { exit !found }'; then
  echo "[s2-keyboard] teleop_twist_keyboard is not installed" >&2
  echo "[s2-keyboard] install it with: sudo apt install ros-humble-teleop-twist-keyboard" >&2
  exit 1
fi

setsid python3 "${ROOT}/tools/s2_nav2_cmd_vel_bridge.py" \
  --controller-host "${S2_CONTROLLER_IP:-192.168.127.10}" \
  --controller-timeout-sec "${S2_CONTROLLER_TIMEOUT_SEC:-2.0}" \
  --robot-id "${S2_ROBOT_ID:-1}" \
  --max-linear-x "${S2_KEYBOARD_MAX_LINEAR_X:-0.06}" \
  --max-linear-y "${S2_KEYBOARD_MAX_LINEAR_Y:-0.06}" \
  --max-angular-z "${S2_KEYBOARD_MAX_ANGULAR_Z:-0.20}" \
  "${MOTION_ARGS[@]}" &
BRIDGE_PID=$!

cleanup() {
  trap - EXIT INT TERM
  if kill -0 "${BRIDGE_PID}" 2>/dev/null; then
    kill -INT "${BRIDGE_PID}" 2>/dev/null || true
  fi
  wait "${BRIDGE_PID}" 2>/dev/null || true
}
trap cleanup EXIT INT TERM

sleep 1
if ! kill -0 "${BRIDGE_PID}" 2>/dev/null; then
  wait "${BRIDGE_PID}"
fi

echo "[s2-keyboard] i/, forward/back; j/l rotate; Shift+u/o/m/. strafe; k stop"
ros2 run teleop_twist_keyboard teleop_twist_keyboard --ros-args \
  -p speed:="${S2_KEYBOARD_MAX_LINEAR_X:-0.06}" \
  -p turn:="${S2_KEYBOARD_MAX_ANGULAR_Z:-0.20}" \
  -r cmd_vel:=/s2_nav2/cmd_vel
